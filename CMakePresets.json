{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "configuration",
      "hidden": true,
      "binaryDir": "${sourceDir}/build",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_CXX_SCAN_FOR_MODULES": "ON",
        "CUSTOMIZE_BUILD": "ON",
        "JSON_ImplicitConversions": "OFF",
        "BUILD_EXAMPLES": "OFF",
        "BUILD_GAMES": "OFF",
        "FETCHCONTENT_QUIET": false
      }
    },
    {
      "name": "web-configuration",
      "hidden": true,
      "inherits": "configuration",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "${sourceDir}/deps/emsdk/upstream/emscripten/em++",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/deps/emsdk/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake",
        "EMSCRIPTEN": "ON",
        "PLATFORM": "Web"
      }
    },
    {
      "name": "flags",
      "hidden": true,
      "environment": {
          "DANCING_LINKS_WARNING_CPP_FLAGS": "-Wall -Wpedantic -Wextra -Wno-deprecated-declarations -Wshadow -Wpointer-arith -Wcast-qual -Wformat=2 -Wno-unqualified-std-cast-call"
      }
    },
    {
      "name": "web-flags",
      "hidden": true,
      "inherits": "flags",
      "environment": {
        "DANCING_LINKS_WEB_C_FLAGS": "-sUSE_GLFW=3 -sASSERTIONS=1 -sWASM=1 -sASYNCIFY -sGL_ENABLE_GET_PROC_ADDRESS=1",
        "DANCING_LINKS_WEB_LINKER_FLAGS": "-sUSE_GLFW=3 -sASSERTIONS=1 -sWASM=1 -sASYNCIFY -sGL_ENABLE_GET_PROC_ADDRESS=1 -sEXPORTED_RUNTIME_METHODS=[requestFullscreen] --preload-file ${sourceDir}/data/font@data/font --preload-file ${sourceDir}/data/maps@data/maps --preload-file ${sourceDir}/data/types@data/types --shell-file ${sourceDir}/html/shell.html --preload-file ${sourceDir}/data/icons/favicon.ico@/"
      }
    },
    {
      "name": "default-debug",
      "hidden": true,
      "inherits": ["configuration", "flags"],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/build/debug/bin",
        "CMAKE_CXX_FLAGS": "-g3 $env{DANCING_LINKS_WARNING_CPP_FLAGS}"
      }
    },
    {
      "name": "default-release",
      "hidden": true,
      "inherits": ["configuration", "flags"],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/build/bin",
        "CMAKE_CXX_FLAGS": "$env{DANCING_LINKS_WARNING_CPP_FLAGS}"
      }
    },
    {
      "name": "clang-debug",
      "inherits": "default-debug",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "clang-release",
      "inherits": "default-release",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "web-debug",
      "inherits": ["web-configuration", "web-flags"],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/build/debug/bin",
        "CMAKE_CXX_FLAGS": "-g3 $env{DANCING_LINKS_WARNING_CPP_FLAGS}",
        "CMAKE_C_FLAGS": "$env{DANCING_LINKS_WEB_C_FLAGS}",
        "CMAKE_EXE_LINKER_FLAGS": "$env{DANCING_LINKS_WEB_LINKER_FLAGS}"
      }
    },
    {
      "name": "web-release",
      "inherits": ["web-configuration", "web-flags"],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "MinSizeRel",
        "CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/build/bin",
        "CMAKE_CXX_FLAGS": "$env{DANCING_LINKS_WARNING_CPP_FLAGS}",
        "CMAKE_C_FLAGS": "$env{DANCING_LINKS_WEB_C_FLAGS}",
        "CMAKE_EXE_LINKER_FLAGS": "$env{DANCING_LINKS_WEB_LINKER_FLAGS}"
      }
    }
  ]
}

